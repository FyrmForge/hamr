.PHONY: dev build test lint migrate db-sh docker-up docker-down docker-delete docker-reload clean install check-reflex check-templ{{- if eq .CSS "tailwind"}} check-node-modules css css-build{{- end}}

## install: Install development dependencies
install:
	go install github.com/cespare/reflex@latest
	go install github.com/a-h/templ/cmd/templ@latest
{{- if eq .CSS "tailwind"}}
	npm install
{{- end}}

## check-reflex: Verify reflex is installed
check-reflex:
	@command -v reflex >/dev/null 2>&1 || { echo "reflex not found. Run: make install" >&2; exit 1; }

## check-templ: Verify templ is installed
check-templ:
	@command -v templ >/dev/null 2>&1 || { echo "templ not found. Run: make install" >&2; exit 1; }
{{- if eq .CSS "tailwind"}}

## check-node-modules: Auto-install npm deps if missing
check-node-modules:
	@[ -d node_modules ] || npm install

## css: Watch and rebuild Tailwind CSS on changes
css: check-node-modules
	npm run css

## css-build: Build Tailwind CSS for production (minified)
css-build: check-node-modules
	npm run css:build
{{- end}}

## dev: Run the server with live reload on .go and .templ changes
dev: check-templ check-reflex{{- if eq .CSS "tailwind"}} check-node-modules{{- end}}
	@templ generate
{{- if eq .CSS "tailwind"}}
	@npm run css:build
	@npm run css &
{{- end}}
	reflex -r '\.(go|templ)$$' -R '_templ\.go$$' -s -- sh -c 'templ generate && go run ./cmd/server'

VERSION := $(shell git rev-parse --short HEAD 2>/dev/null || echo "dev")

## build: Build the server binary
build: check-templ{{- if eq .CSS "tailwind"}} check-node-modules{{- end}}
	templ generate
{{- if eq .CSS "tailwind"}}
	npm run css:build
{{- end}}
	go build -ldflags "-X main.version=$(VERSION)" -o bin/server ./cmd/server

## test: Run all tests
test: check-templ
	templ generate
	go test ./...

## migrate: Run database migrations
migrate:
	go run ./cmd/migrate

## db-sh: Open a pgcli shell to the local dev database
db-sh:
	bash ./db-sh

## lint: Run linters
lint:
	golangci-lint run

## docker-up: Start Docker services
docker-up:
	docker compose -f docker/docker-compose.yaml up -d

## docker-down: Stop Docker services
docker-down:
	docker compose -f docker/docker-compose.yaml down

## docker-delete: Delete Docker containers and volumes
docker-delete:
	docker compose -f docker/docker-compose.yaml down -v

## docker-reload: Delete and recreate Docker services
docker-reload: docker-delete docker-up
{{- if .S3StaticWatcher}}

## sync-static: Watch static/ and sync changes to S3
sync-static:
	hamr sync --watch
{{- end}}
{{- if .IncludeE2E}}

## e2e: Run E2E tests (containerized)
e2e:
	go test -v -tags=e2e ./e2e-go -timeout 10m

## e2e-local: Run E2E tests against local server
e2e-local:
	go test -v -tags=e2e ./e2e-go -local -timeout 10m

## e2e-run: Run specific E2E test: make e2e-run T=TestName
e2e-run:
	go test -v -tags=e2e ./e2e-go -run "$(T)" -timeout 5m

## e2e-run-local: Run specific E2E test locally: make e2e-run-local T=TestName
e2e-run-local:
	go test -v -tags=e2e ./e2e-go -local -run "$(T)" -timeout 2m
{{- end}}

## clean: Remove build artifacts
clean:
	rm -rf bin/ coverage.out coverage.html
