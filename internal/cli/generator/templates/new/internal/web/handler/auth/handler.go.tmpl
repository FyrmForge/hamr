// POST /register
func (h *handler) Register(c echo.Context) error {
	name := c.FormValue("name")
	email := c.FormValue("email")
	password := c.FormValue("password")

	errs := make(map[string]string)
	if msg := validate.Required(name); msg != "" {
		errs["name"] = msg
	}
	if msg := validate.Email(email); msg != "" {
		errs["email"] = msg
	}
	if msg := validate.PasswordStrength(password); msg != "" {
		errs["password"] = msg
	}
	if len(errs) > 0 {
		middleware.SetFlash(c, "Please fix the errors below", middleware.FlashError)
		return c.Redirect(http.StatusSeeOther, "/register")
	}

	user, err := h.authService.Register(c.Request().Context(), email, password, name)
	if err != nil {
		h.log.Warn("registration failed", "email", email, "error", err)
		middleware.SetFlash(c, "Registration failed: "+err.Error(), middleware.FlashError)
		return c.Redirect(http.StatusSeeOther, "/register")
	}

	session, err := h.sessionManager.CreateSession(c.Request().Context(), user.ID, nil)
	if err != nil {
		h.log.Error("create session failed", "error", err)
		return echo.NewHTTPError(http.StatusInternalServerError, "session error")
	}

	c.SetCookie(&http.Cookie{
		Name:     h.sessionManager.CookieName(),
		Value:    session.Token,
		Path:     h.sessionManager.CookiePath(),
		HttpOnly: true,
		Secure:   h.sessionManager.CookieSecure(),
		SameSite: h.sessionManager.SameSite(),
	})

	middleware.SetFlash(c, "Welcome! Your account has been created.", middleware.FlashSuccess)
	return c.Redirect(http.StatusSeeOther, "/")
}

// POST /logout
func (h *handler) Logout(c echo.Context) error {
	cookie, err := c.Cookie(h.sessionManager.CookieName())
	if err == nil {
		session, _ := h.sessionManager.ValidateSession(c.Request().Context(), cookie.Value)
		if session != nil {
			_ = h.sessionManager.DeleteSession(c.Request().Context(), session.ID)
		}
	}

	c.SetCookie(&http.Cookie{
		Name:     h.sessionManager.CookieName(),
		Value:    "",
		Path:     h.sessionManager.CookiePath(),
		MaxAge:   -1,
		HttpOnly: true,
		Secure:   h.sessionManager.CookieSecure(),
		SameSite: h.sessionManager.SameSite(),
	})

	middleware.SetFlash(c, "You have been logged out", middleware.FlashInfo)
	return c.Redirect(http.StatusSeeOther, "/login")
}
