FROM golang:{{.GoVersion}}-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /bin/{{.Name}} ./cmd/{{.Name}}

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=builder /bin/{{.Name}} /bin/{{.Name}}
ENTRYPOINT ["/bin/{{.Name}}"]
