package config

import "os"

// Config holds the configuration for the {{.Name}} service.
type Config struct {
	Port string
}

// Load reads configuration from environment variables.
func Load() *Config {
	return &Config{
		Port: getEnvOrDefault("PORT", "8080"),
	}
}

func getEnvOrDefault(key, def string) string {
	if v := os.Getenv(key); v != "" {
		return v
	}
	return def
}
