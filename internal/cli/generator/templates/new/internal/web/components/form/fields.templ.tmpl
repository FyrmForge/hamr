package form

// FieldError renders a validation error message for a form field.
templ FieldError(field string, errors map[string]string) {
	if msg, ok := errors[field]; ok {
		<div class="field-error" id={ field + "-error" }>{ msg }</div>
	}
}

// FieldErrorOOB renders an out-of-band swap for a field error (used with HTMX).
templ FieldErrorOOB(field string, msg string) {
	<div class="field-error" id={ field + "-error" } hx-swap-oob="true">
		if msg != "" {
			{ msg }
		}
	</div>
}

// CSRFField renders a hidden CSRF token input.
templ CSRFField(token string) {
	<input type="hidden" name="csrf_token" value={ token }/>
}
