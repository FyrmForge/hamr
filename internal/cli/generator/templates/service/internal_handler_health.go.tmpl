package handler

import (
	"net/http"

	"github.com/labstack/echo/v4"
)

// RegisterHealth registers the health check endpoint.
func RegisterHealth(e *echo.Echo) {
	e.GET("/health", health)
}

func health(c echo.Context) error {
	return c.JSON(http.StatusOK, map[string]string{
		"status":  "ok",
		"service": "{{.Name}}",
	})
}
