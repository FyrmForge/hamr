# Server
PORT=8080
PRODUCTION=false

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/{{.Name}}?sslmode=disable
{{- if eq .StorageBackend "local"}}

# Storage
STORAGE_PATH=./uploads
{{- end}}
{{- if eq .StorageBackend "s3"}}

# S3 Storage (MinIO)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET={{.Name}}-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
{{- end}}

# Static assets base URL (override with CDN URL in production)
{{- if .S3StaticWatcher}}
STATIC_BASE_URL=http://localhost:9000/{{.Name}}-uploads
{{- else}}
STATIC_BASE_URL=/static
{{- end}}
